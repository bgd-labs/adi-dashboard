# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

# PostgreSQL connection string (Supabase shared pooler, port 6543)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?sslmode=require"
# Any random string to protect the API endpoints
CRON_SECRET=""
# Slack bot token (xoxb-...)
SLACK_BOT_TOKEN=""
# Slack channel ID to post notifications to
SLACK_CHANNEL_ID=""
# Any random string to protect the ICON generator endpoint
ICON_GENERATOR_KEY=""
# Environment stage (PREPROD | PROD)
ENVIRONMENT_STAGE=""
# CoinGecko API key
COINGECKO_API_KEY=""
# Alchemy API key
ALCHEMY_API_KEY=""